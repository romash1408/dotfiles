{{- if not .offline -}}
#!/bin/bash
# Installs Homebrew (if missing) and all packages from .chezmoidata/packages.toml.
# run_onchange: re-runs whenever the rendered package list below changes.
set -e

{{ if and (eq .chezmoi.os "linux") .packages.linux.apt -}}
# apt packages first: installed even where brew is skipped (old glibc)
_missing=""
{{ range .packages.linux.apt -}}
command -v {{ . }} >/dev/null 2>&1 || _missing="$_missing {{ . }}"
{{ end -}}
if [ -n "$_missing" ]; then
  echo "==> apt install:$_missing"
  sudo apt-get install -y $_missing
fi
{{ end -}}

{{ if eq .chezmoi.os "linux" -}}
# Homebrew bottles need glibc >= 2.35; on older hosts brew builds the whole
# toolchain from source, which kills small VPSes (backup: Debian 11, 1GB RAM).
# Rendered glibc version makes run_onchange re-fire after an OS upgrade:
# host glibc: {{ output "ldd" "--version" | trim | splitList "\n" | first }}
_glibc=$(ldd --version | head -1 | grep -oE '[0-9]+\.[0-9]+$')
if [ "$(printf '2.35\n%s\n' "$_glibc" | sort -V | head -1)" != "2.35" ]; then
  echo "==> SKIP packages: glibc $_glibc < 2.35, no usable bottles on this host"
  exit 0
fi
{{ end -}}

for _p in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew; do
  if [ -x "$_p/bin/brew" ]; then BREW="$_p/bin/brew"; break; fi
done

if [ -z "$BREW" ]; then
  echo "==> Installing Homebrew..."
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  for _p in /opt/homebrew /usr/local /home/linuxbrew/.linuxbrew; do
    if [ -x "$_p/bin/brew" ]; then BREW="$_p/bin/brew"; break; fi
  done
  [ -n "$BREW" ] || { echo "ERROR: brew not found after install" >&2; exit 1; }
fi

eval "$("$BREW" shellenv)"

{{ if and (eq .chezmoi.os "linux") .hasGUI .packages.linux.flatpaks -}}
if ! command -v flatpak >/dev/null 2>&1; then
  echo "==> Installing flatpak..."
  sudo apt-get install -y flatpak
fi
flatpak remote-add --if-not-exists --user flathub https://dl.flathub.org/repo/flathub.flatpakrepo
{{ end -}}

echo "==> brew bundle..."
brew bundle --file=- <<'BREWFILE'
{{ range .packages.brews -}}
brew "{{ . }}"
{{ end -}}
{{ if eq .chezmoi.os "darwin" -}}
{{ range .packages.darwin.brews -}}
brew "{{ . }}"
{{ end -}}
{{ range .packages.darwin.casks -}}
cask "{{ . }}"
{{ end -}}
{{ end -}}
{{ if and (eq .chezmoi.os "linux") .hasGUI -}}
{{ range .packages.linux.flatpaks -}}
flatpak "{{ . }}"
{{ end -}}
{{ end -}}
BREWFILE
echo "==> Packages done."
{{- end -}}
